# =========================
# APPLICATION
# =========================

APP_NAME=Spice Girl
APP_VERSION=1.0.0
DEBUG=True

# =========================
# DATABASE
# =========================

DATABASE_URL=postgresql://postgres:password@localhost:5432/spicegirl

# =========================
# JWT AUTHENTICATION
# =========================

JWT_SECRET_KEY=spicegirl_super_secret_key_2026_change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =========================
# WEATHER API
# =========================

WEATHER_API_KEY=your_openweathermap_api_key

# =========================
# GOOGLE CALENDAR API
# =========================

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

GOOGLE_CLIENT_SECRET=your_google_client_secret

GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/events/callback